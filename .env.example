# teacher-mcp 配置（凭据不入 git，copy 为 .env 后填）
# PRD-O-005 重建：A/C 双线已合并为同一 book-server 服务（新区 :9090）
RUOYI_BASE_URL=http://localhost:9090
# toolkit（LangGraph 举一反三，FastAPI 非 RuoYi，:9093）——health_check 探针用
TOOLKIT_BASE_URL=http://localhost:9093
# RuoYi 客户端 id / 租户（双头鉴权用，非密）
RUOYI_CLIENT_ID=e5cd7e4891bf95d1d19206ce24a7b32e
RUOYI_TENANT_ID=000000

# 🔴 真账号身份：正式由 MCP `login(username,password)` 工具传参注入。
# 下面两项仅作 login 不传参时的兜底 + 冒烟脚本用，凭据走 .env 不提交。
RUOYI_USERNAME=
RUOYI_PASSWORD=

# dev 库直连（模型链/难度依据/卷目录/KG查表 pymysql 收口，见 backends/db.py）
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=123456
DB_DATABASE=ai_lesson_prep
