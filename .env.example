# teacher-mcp 配置（凭据不入 git，copy 为 .env 后填）
# 平台 book-server 底座地址（PRD-C-208 录入角色指 A 线录入 BE :8080；探针组卷曾用 C 线 :8090）
RUOYI_BASE_URL=http://localhost:8080
# 多底座路由：C 线底座（讲义接口 :8090）——同库同账号、token 互不通用，cluster 懒登录
RUOYI_C_BASE_URL=http://localhost:8090
# toolkit（FastAPI 非 RuoYi，:8093）——占位，本期未实现 client
TOOLKIT_BASE_URL=http://localhost:8093
# RuoYi 客户端 id / 租户（双头鉴权用，非密）
RUOYI_CLIENT_ID=e5cd7e4891bf95d1d19206ce24a7b32e
RUOYI_TENANT_ID=000000

# 🔴 真账号身份：正式由 MCP `login(username,password)` 工具传参注入。
# 下面两项仅作 login 不传参时的兜底 + 冒烟脚本用，凭据走 .env 不提交。
RUOYI_USERNAME=
RUOYI_PASSWORD=

# dev 库直连（PRD-C-208 3.3-b：模型链/难度依据/卷目录/KG查表 pymysql 收口，见 app/db.py）
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=123456
DB_DATABASE=ai_lesson_prep
